- name: Update keycloak-services on Ubuntu
  hosts: ubuntu_servers
  become: yes
  tasks:
    - name: Update keycloak-services to version 22.0.13
      apt:
        name: keycloak-services
        version: 22.0.13
        state: present
      when: ansible_distribution_major_version == "20"

    - name: Ensure keycloak-services is installed
      apt:
        name: keycloak-services
        state: present
      when: ansible_distribution_major_version == "20"